# Imagem do Rundeck (padrão: stable 5.20.1)
RUNDECK_IMAGE=rundeck/rundeck:5.20.1

# URL de acesso ao Rundeck (ajuste conforme seu ambiente)
RUNDECK_GRAILS_URL=http://localhost:4440

# Descomente abaixo se tiver licença Enterprise
# RUNDECK_IMAGE=rundeckpro/enterprise:SNAPSHOT
# RUNDECK_LICENSE_FILE=./rundeck-license.key
